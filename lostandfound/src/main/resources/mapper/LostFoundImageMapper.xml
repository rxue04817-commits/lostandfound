<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.bean.lostandfound.mapper.LostFoundImageMapper">
    <insert id="insert">
        INSERT INTO lost_found_image(lost_found_id, image_url, created_at)
        VALUES (#{lostFoundId}, #{imageUrl}, #{createdAt})
    </insert>


    <select id="selectByLostFoundId" resultType="com.bean.lostandfound.pojo.entity.LostFoundImage">
        SELECT * FROM lost_found_image WHERE lost_found_id = #{lostFoundId}
    </select>
</mapper>
