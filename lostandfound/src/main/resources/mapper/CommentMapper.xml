<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.bean.lostandfound.mapper.CommentMapper">


    <select id="getByLostFoundId" resultType="com.bean.lostandfound.pojo.entity.Comment">
        SELECT * FROM comment WHERE lost_found_id = #{id}
        order by created_at asc
    </select>
</mapper>
